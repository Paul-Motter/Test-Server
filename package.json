        "packageManager": {
            "name": "pnpm",
            "version": "^11.11.0",
            "onFail": "download"
        }
    },
    "type": "module",
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "pg": "^8.22.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "@types/pg": "^8.20.0",
        "dotenv-cli": "^11.0.0",
        "supabase": "^2.109.1",
        "tsup": "^8.5.1",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2"
    }
