{
    "name": "Test_Server",
    "version": "1.0.0",
    "description": "",
    "main": "dist/index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "tsup src/index.ts --format esm",
